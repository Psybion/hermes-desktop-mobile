+  html[data-hermes-browser='true'] [data-slot='composer-surface'] {
+    border-radius: 1.125rem;
+    box-shadow:
+      0 12px 32px rgb(0 0 0 / 24%),
+      0 0 0 1px color-mix(in srgb, var(--ui-stroke-secondary) 60%, transparent);
+  }
+
+  html[data-hermes-browser='true'] [data-slot='composer-fade'] {
+    --composer-surface-pad-x: 0.75rem;
+    --composer-surface-pad-y: 0.625rem;
+  }
+
+  html[data-hermes-browser='true'] [contenteditable='true'] {
+    min-height: 2.4rem;
+    max-height: min(32dvh, 14rem);
+    font-size: 1rem;
+    line-height: 1.45;
+  }
+
+  html[data-hermes-browser='true'] [data-slot='composer-model-pill'],
+  html[data-hermes-browser='true'] [data-slot='composer-dictation'],
+  html[data-hermes-browser='true'] [data-slot='composer-auto-speak'] {
+    display: none;
+  }
+
+  html[data-hermes-browser='true'] [data-pane-hover-reveal] > div:last-child {
+    width: min(88vw, 22rem) !important;
+    max-width: calc(100vw - 2.75rem);
+  }
+
+  html[data-hermes-browser='true'] [data-pane-reveal-trigger] {
+    display: none;
+  }
+
+  html[data-hermes-browser='true'] [data-pane-main='true'] {
+    min-width: 0;
+  }
+
+  html[data-hermes-browser='true'] [data-slot='aui_user-message-root'],
+  html[data-hermes-browser='true'] [data-slot='aui_assistant-message-content'] {
+    max-width: 100%;
+  }
+
+  html[data-hermes-browser='true'] [data-slot='dialog-content'],
+  html[data-hermes-browser='true'] [data-slot='command-dialog-content'] {
+    width: calc(100vw - 1rem);
+    max-width: calc(100vw - 1rem);
+    max-height: calc(var(--hermes-viewport-height, 100dvh) - 1rem - env(safe-area-inset-top));
+    border-radius: 1rem;
+  }
+
+  html[data-hermes-browser='true'] input,
+  html[data-hermes-browser='true'] textarea,
+  html[data-hermes-browser='true'] select {
+    font-size: 1rem;
+  }
+}
