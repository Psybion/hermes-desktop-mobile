diff --git a/apps/desktop/src/browser-bridge.test.ts b/apps/desktop/src/browser-bridge.test.ts
new file mode 100644
index 0000000..12dde21
--- /dev/null
+++ b/apps/desktop/src/browser-bridge.test.ts
@@ -0,0 +1,191 @@
+import { beforeEach, describe, expect, it, vi } from 'vitest'
+
+import { installBrowserBridge } from './browser-bridge'
+
+type BrowserContract = Window['hermesDesktop'] & {
+  cloud: { status: () => Promise<{ portalBaseUrl: string; signedIn: boolean }> }
+}
+
+function desktop(): BrowserContract {
+  return window.hermesDesktop as BrowserContract
+}
+
+beforeEach(() => {
+  Object.defineProperty(window, 'hermesDesktop', { configurable: true, value: undefined, writable: true })
+  Object.defineProperty(window, '__HERMES_DESKTOP_TOKEN__', { configurable: true, value: 'test-token' })
+  vi.stubGlobal(
+    'fetch',
+    vi.fn(async (input: RequestInfo | URL) => {
+      const url = String(input)
+
+      const payload = url.includes('/api/status')
+        ? { version: '1.2.3' }
+        : url.includes('/api/git/base-branches')
+          ? { branches: [{ isDefault: true, isRemote: true, name: 'origin/main' }] }
+          : url.includes('/api/git/branches')
+            ? { branches: [{ isDefault: false, name: 'local-only' }] }
+            : url.includes('/api/fs/list')
+              ? { entries: [{ isDirectory: false, name: 'README.md', path: '/repo/README.md' }] }
+              : url.includes('/api/fs/git-root')
+                ? { root: '/repo' }
+                : {}
+
+      return new Response(JSON.stringify(payload), {
+        headers: { 'Content-Type': 'application/json' },
+        status: 200
+      })
+    })
+  )
+  vi.spyOn(window, 'open').mockImplementation(() => null)
+})
+
+describe('browser bridge contract', () => {
+  it('provides required browser-safe Desktop API groups without undefined members', async () => {
+    installBrowserBridge()
+    const api = desktop()
+
+    for (const method of [
+      'getConnection',
+      'getGatewayWsUrl',
+      'normalizePreviewTarget',
+      'watchPreviewFile',
+      'stopPreviewFileWatch',
+      'readDir',
+      'getVersion'
+    ] as const) {
+      expect(typeof api[method]).toBe('function')
+    }
+
+    for (const group of ['petOverlay', 'terminal', 'updates', 'uninstall', 'themes', 'git', 'cloud'] as const) {
+      expect(api[group]).toBeTruthy()
+    }
+
+    await expect(api.getVersion()).resolves.toEqual({
+      appVersion: '1.2.3',
+      electronVersion: 'browser',
+      hermesRoot: '',
+      nodeVersion: 'browser',
+      platform: 'web'
+    })
+  })
+
+  it('routes filesystem and Git reads through the authenticated gateway API', async () => {
+    installBrowserBridge()
+    const api = desktop()
+
+    await expect(api.readDir('/repo')).resolves.toEqual({
+      entries: [{ isDirectory: false, name: 'README.md', path: '/repo/README.md' }]
+    })
+    await expect(api.gitRoot?.('/repo/file.ts')).resolves.toBe('/repo')
+
+    expect(fetch).toHaveBeenCalledWith(
+      '/api/fs/list?path=%2Frepo',
+      expect.objectContaining({ headers: expect.objectContaining({ 'X-Hermes-Session-Token': 'test-token' }) })
+    )
+  })
+
+  it('loads start-work bases from the dedicated remote-aware gateway endpoint', async () => {
+    installBrowserBridge()
+    const api = desktop()
+
+    await expect(api.git!.baseBranchList('/repo')).resolves.toEqual([
+      { isDefault: true, isRemote: true, name: 'origin/main' }
+    ])
+
+    expect(fetch).toHaveBeenCalledWith(
+      '/api/git/base-branches?path=%2Frepo',
+      expect.objectContaining({ headers: expect.objectContaining({ 'X-Hermes-Session-Token': 'test-token' }) })
+    )
+  })
+
+  it('reuses and focuses an open session window without navigating it again', async () => {
+    const focus = vi.fn()
+    const opened = { closed: false, focus, opener: window } as unknown as Window
+    vi.mocked(window.open).mockReturnValue(opened)
+    installBrowserBridge()
+    const api = desktop()
+
+    await expect(api.openSessionWindow('session / one', { watch: true })).resolves.toEqual({ ok: true })
+    await expect(api.openSessionWindow('session / one', { watch: true })).resolves.toEqual({ ok: true })
+    expect(window.open).toHaveBeenCalledWith(
+      `${window.location.origin}${window.location.pathname}?win=secondary&watch=1#/session%20%2F%20one`,
+      'hermes-session-session%20%2F%20one'
+    )
+    expect(window.open).toHaveBeenCalledTimes(1)
+    expect(opened.opener).toBeNull()
+    expect(focus).toHaveBeenCalledTimes(2)
+  })
+
+  it('preserves new-session window semantics', async () => {
+    const focus = vi.fn()
+    const opened = { focus, opener: window } as unknown as Window
+    vi.mocked(window.open).mockReturnValue(opened)
+    installBrowserBridge()
+    const api = desktop()
+
+    await expect(api.openNewSessionWindow()).resolves.toEqual({ ok: true })
+    expect(window.open).toHaveBeenCalledWith(
+      `${window.location.origin}${window.location.pathname}?win=secondary&new=1#/`,
+      '_blank'
+    )
+    expect(opened.opener).toBeNull()
+    expect(focus).toHaveBeenCalledTimes(1)
+  })
+
+  it('reports blocked browser popups instead of claiming success', async () => {
+    installBrowserBridge()
+    const api = desktop()
+
+    await expect(api.openSessionWindow('blocked-session')).resolves.toEqual({
+      error: 'popup-blocked',
+      ok: false
+    })
+    await expect(api.openNewSessionWindow()).resolves.toEqual({ error: 'popup-blocked', ok: false })
+  })
+
+  it('resolves an empty selection when the browser file picker is cancelled', async () => {
+    const created = vi.spyOn(document, 'createElement')
+    installBrowserBridge()
+
+    const selection = desktop().selectPaths()
+    const input = created.mock.results.find(result => result.value instanceof HTMLInputElement)?.value
+
+    expect(input).toBeInstanceOf(HTMLInputElement)
+    input?.dispatchEvent(new Event('cancel'))
+    await expect(selection).resolves.toEqual([])
+  })
+
+  it('fails closed for connection settings that are managed by the browser deployment', async () => {
+    installBrowserBridge()
+    const api = desktop()
+    const payload = { mode: 'local' as const }
+
+    await expect(api.saveConnectionConfig(payload)).rejects.toThrow('managed by the browser deployment')
+    await expect(api.applyConnectionConfig(payload)).rejects.toThrow('managed by the browser deployment')
+    await expect(api.testConnectionConfig(payload)).rejects.toThrow('managed by the browser deployment')
+    await expect(api.probeConnectionConfig('https://example.invalid')).rejects.toThrow(
+      'managed by the browser deployment'
+    )
+    await expect(api.oauthLoginConnectionConfig('https://example.invalid')).rejects.toThrow(
+      'managed by the browser deployment'
+    )
+    await expect(api.oauthLogoutConnectionConfig()).rejects.toThrow('managed by the browser deployment')
+  })
+
+  it('fails closed for native-only terminal, update, and uninstall actions', async () => {
+    installBrowserBridge()
+    const api = desktop()
+
+    await expect(api.terminal.start()).rejects.toThrow('not available in the browser client')
+    await expect(api.updates.check()).resolves.toMatchObject({
+      message: 'Update hermes-mobile-desktop to a reviewed release.',
+      supported: false
+    })
+    await expect(api.updates.apply()).resolves.toMatchObject({
+      command: 'Update hermes-mobile-desktop to a reviewed release.',
+      error: expect.stringContaining('not available')
+    })
+    await expect(api.uninstall.run('gui')).resolves.toMatchObject({ ok: false })
+    await expect(api.cloud.status()).resolves.toEqual({ portalBaseUrl: '', signedIn: false })
+  })
+})
diff --git a/apps/desktop/src/browser-bridge.ts b/apps/desktop/src/browser-bridge.ts
new file mode 100644
index 0000000..495e0c1
--- /dev/null
+++ b/apps/desktop/src/browser-bridge.ts
@@ -0,0 +1,679 @@
+import type {
+  DesktopActiveProfile,
+  DesktopBootProgress,
+  DesktopConnectionConfig,
+  DesktopUninstallMode,
+  DesktopUninstallResult,
+  DesktopUninstallSummary,
+  DesktopUpdateApplyOptions,
+  DesktopUpdateApplyResult,
+  DesktopUpdateStatus,
+  HermesApiRequest,
+  HermesConnection,
+  HermesGitBranch,
+  HermesGitWorktree,
+  HermesReadDirResult,
+  HermesReadFileTextResult,
+  HermesRepoStatus,
+  HermesReviewList,
+  HermesReviewScope,
+  HermesReviewShipInfo,
+  HermesSelectPathsOptions
+} from './global'
+
+type BrowserBootstrapWindow = Window & {
+  __HERMES_DESKTOP_TOKEN__?: string
+}
+
+const PROFILE_STORAGE_KEY = 'hermes.desktop.web.profile'
+const UPLOAD_ROOT = '/tmp/hermes-desktop-web'
+const noopOff = () => undefined
+
+function token(): string {
+  const value = (window as BrowserBootstrapWindow).__HERMES_DESKTOP_TOKEN__?.trim()
+
+  if (!value) {
+    throw new Error('Hermes Desktop Web was served without a gateway token.')
+  }
+
+  return value
+}
+
+function selectedProfile(): string | null {
+  return window.localStorage.getItem(PROFILE_STORAGE_KEY)?.trim() || null
+}
+
+function withProfile(path: string, profile?: null | string): string {
+  if (!profile) {
+    return path
+  }
+
+  const url = new URL(path, window.location.origin)
+
+  if (!url.searchParams.has('profile')) {
+    url.searchParams.set('profile', profile)
+  }
+
+  return `${url.pathname}${url.search}${url.hash}`
+}
+
+function endpoint(path: string, params: Record<string, boolean | null | string | undefined> = {}): string {
+  const query = new URLSearchParams()
+
+  for (const [name, value] of Object.entries(params)) {
+    if (value !== null && value !== undefined && value !== '') {
+      query.set(name, String(value))
+    }
+  }
+
+  const suffix = query.toString()
+
+  return suffix ? `${path}?${suffix}` : path
+}
+
+function nativeOnly(feature: string): Error {
+  return new Error(`${feature} is not available in the browser client.`)
+}
+
+function deploymentManaged(feature: string): Error {
+  return new Error(`${feature} are managed by the browser deployment.`)
+}
+
+function openBrowserWindow(
+  url: string,
+  target: string,
+  onOpened?: (opened: Window) => void
+): { error?: string; ok: boolean } {
+  const opened = window.open(url, target)
+
+  if (!opened) {
+    return { error: 'popup-blocked', ok: false }
+  }
+
+  opened.opener = null
+  onOpened?.(opened)
+  opened.focus()
+
+  return { ok: true }
+}
+
+async function api<T>({ body, method = 'GET', path, profile, timeoutMs = 30_000 }: HermesApiRequest): Promise<T> {
+  if (!path.startsWith('/api/')) {
+    throw new Error(`Hermes Desktop Web refused a non-API path: ${path}`)
+  }
+
+  const controller = new AbortController()
+  const timer = window.setTimeout(() => controller.abort(), timeoutMs)
+
+  try {
+    const response = await fetch(withProfile(path, profile), {
+      body: body === undefined ? undefined : JSON.stringify(body),
+      credentials: 'same-origin',
+      headers: {
+        Accept: 'application/json',
+        ...(body === undefined ? {} : { 'Content-Type': 'application/json' }),
+        'X-Hermes-Session-Token': token()
+      },
+      method,
+      signal: controller.signal
+    })
+
+    const text = await response.text()
+    let payload: unknown = null
+
+    if (text) {
+      try {
+        payload = JSON.parse(text)
+      } catch {
+        payload = text
+      }
+    }
+
+    if (!response.ok) {
+      const detail =
+        payload && typeof payload === 'object' && 'detail' in payload
+          ? String((payload as { detail?: unknown }).detail)
+          : typeof payload === 'string'
+            ? payload
+            : response.statusText
+
+      throw new Error(`${response.status}: ${detail || 'Hermes request failed'}`)
+    }
+
+    return payload as T
+  } finally {
+    window.clearTimeout(timer)
+  }
+}
+
+function wsUrl(profile?: null | string): string {
+  const scheme = window.location.protocol === 'https:' ? 'wss:' : 'ws:'
+  const query = new URLSearchParams({ token: token() })
+
+  if (profile) {
+    query.set('profile', profile)
+  }
+
+  return `${scheme}//${window.location.host}/api/ws?${query.toString()}`
+}
+
+function connection(profile?: null | string): HermesConnection {
+  return {
+    authMode: 'token',
+    baseUrl: window.location.origin,
+    isFullscreen: false,
+    logs: [],
+    mode: 'remote',
+    nativeOverlayWidth: 0,
+    profile: profile || selectedProfile() || undefined,
+    source: 'settings',
+    token: token(),
+    windowButtonPosition: null,
+    wsUrl: wsUrl(profile || selectedProfile())
+  }
+}
+
+const bootProgress = (): DesktopBootProgress => ({
+  error: null,
+  fakeMode: false,
+  message: 'Hermes Desktop Web is ready',
+  phase: 'renderer.ready',
+  progress: 100,
+  running: false,
+  timestamp: Date.now()
+})
+
+function connectionConfig(profile?: null | string): DesktopConnectionConfig {
+  const config: DesktopConnectionConfig & { cloudOrg: string } = {
+    cloudOrg: '',
+    envOverride: true,
+    mode: 'remote',
+    profile: profile || null,
+    remoteAuthMode: 'token',
+    remoteOauthConnected: false,
+    remoteTokenPreview: 'Tailnet session',
+    remoteTokenSet: true,
+    remoteUrl: window.location.origin
+  }
+
+  return config
+}
+
+async function writeClipboard(text: string): Promise<boolean> {
+  await navigator.clipboard.writeText(text)
+
+  return true
+}
+
+async function uploadBlob(blob: Blob, filename: string): Promise<string> {
+  const safeName = filename.replace(/[^A-Za-z0-9._-]+/g, '-').replace(/^-+/, '') || 'attachment.bin'
+  const path = `${UPLOAD_ROOT}/${crypto.randomUUID()}-${safeName}`
+  const bytes = new Uint8Array(await blob.arrayBuffer())
+  let binary = ''
+
+  for (let i = 0; i < bytes.length; i += 0x8000) {
+    binary += String.fromCharCode(...bytes.subarray(i, i + 0x8000))
+  }
+
+  const dataUrl = `data:${blob.type || 'application/octet-stream'};base64,${btoa(binary)}`
+
+  const result = await api<{ path: string }>({
+    body: { data_url: dataUrl, overwrite: true, path },
+    method: 'POST',
+    path: '/api/files/upload'
+  })
+
+  return result.path || path
+}
+
+async function selectPaths(options: HermesSelectPathsOptions = {}): Promise<string[]> {
+  if (options.directories) {
+    return []
+  }
+
+  return new Promise(resolve => {
+    const input = document.createElement('input')
+    input.type = 'file'
+    input.multiple = Boolean(options.multiple)
+    const extensions = options.filters?.flatMap(filter => filter.extensions || []) ?? []
+
+    if (extensions.length) {
+      input.accept = extensions.map(ext => `.${ext.replace(/^\./, '')}`).join(',')
+    }
+
+    input.addEventListener(
+      'change',
+      () => {
+        void Promise.all([...Array.from(input.files || [])].map(file => uploadBlob(file, file.name)))
+          .then(resolve)
+          .catch(error => {
+            console.error('[Hermes Desktop Web] upload failed', error)
+            resolve([])
+          })
+      },
+      { once: true }
+    )
+    input.addEventListener('cancel', () => resolve([]), { once: true })
+    input.click()
+  })
+}
